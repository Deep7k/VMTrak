# VMTrak — backend environment variables
# Copy this file to .env and fill in the values before first run.
#
# Generate the three secrets with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Run that command three times — use a different value for each secret.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Container timezone — affects cron schedule times and log timestamps.
# Use a tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=Asia/Kolkata

# The full URL the frontend is served from (used for CORS).
# In Docker behind a reverse proxy this is the proxy's public URL.
FRONTEND_URL=https://vmtrak.yourdomain.internal

# ── Auth tokens ───────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_64_char_hex
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Credential encryption ─────────────────────────────────────────────────────
# AES-256-GCM key — must be exactly 32 bytes (64 hex chars).
# WARNING: changing this after VMs have credentials will make existing
# passwords unreadable. Back up the DB before rotating.
CREDENTIAL_ENCRYPTION_KEY=replace_with_64_char_hex

# ── SMTP (IP-authenticated relay — no username/password needed) ───────────────
SMTP_HOST=your-postfix-relay-host
SMTP_PORT=25
SMTP_FROM=vminventory@yourdomain.internal
# HELO hostname sent to the relay — set to the docker host's FQDN.
# Without this the container sends [127.0.0.1] which some relays reject.
SMTP_HELO=your-docker-host.yourdomain.internal
# Note: notification recipients are managed per-user in the app (notify_expiry toggle).
# NOTIFY_ADMIN_EMAIL is no longer used.

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# VMTrak — environment variable template
# Copy to .env and fill in real values. Never commit .env.

# ── Application ───────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://vminventory.yourdomain.internal

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_HEX
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ── Credential Encryption ─────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_64_CHAR_HEX

# ── SMTP (Postfix M365 IP relay — no credentials needed) ─────────────────────
SMTP_HOST=your-postfix-relay-host
SMTP_PORT=25
SMTP_FROM=vminventory@yourdomain.internal
NOTIFY_ADMIN_EMAIL=itadmin@yourdomain.internal

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Storage paths (used inside container; usually leave as-is) ────────────────
# DATA_DIR=/app/data
# LOGS_DIR=/app/logs
